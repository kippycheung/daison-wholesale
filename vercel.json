{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/*.js": { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*)\\.jsx",
      "headers": [{ "key": "Content-Type", "value": "text/babel; charset=utf-8" }]
    },
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ]
}
